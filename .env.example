# FitScan Environment Configuration Template
# Get your Gemini API key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: HMR Colab server URL (from colab_server.py ngrok output)
# COLAB_URL=https://xxxx-xx-xx-xx-xx.ngrok-free.app

# Optional: Gaussian Splatting Colab URL (from gaussian_server.py ngrok output)
# GAUSSIAN_COLAB_URL=https://yyyy-yy-yy-yy-yy.ngrok-free.app

# Flask Secret Key
# SECRET_KEY=your_secret_key_here
